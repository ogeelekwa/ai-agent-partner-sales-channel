{
  "name": "ai-agent-partner-sales-channel-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Shopify Inc.",
  "engines": {
    "node": ">=20.19 <22 || >=22.12 || >=24"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "typecheck": "react-router typegen && graphql-codegen && tsc",
    "prestart": "pnpm setup",
    "postinstall": "[ -z \"$CI\" ] && pnpm setup || true",
    "setup": "pnpm db:migrate",
    "shopify": "shopify",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "refresh-graphql": "graphql-codegen",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint ."
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@shopify/admin-api-client": "^1.1.2",
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/i18next-shopify": "^0.2.11",
    "@shopify/polaris": "^13.9.5",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/shopify-app-react-router": "^1.1.1",
    "@shopify/shopify-app-session-storage-drizzle": "^3.0.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "i18next": "^25.8.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.37",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router": "7.12.0",
    "remix-i18next": "^7.4.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@react-router/dev": "7.12.0",
    "@shopify/api-codegen-preset": "^1.2.2",
    "@shopify/cli": "^3.90.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.19.8",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "graphql-config": "^5.1.6",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^8.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "@types/eslint": "^9.6.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2"
  }
}
